{
  "name": "@starweb-libs/physics",
  "description": "SAT and circle collision detection for the browser",
  "author": "Mason L'Etoile",
  "version": "0.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starweb-libs/physics.git"
  },
  "homepage": "https://github.com/starweb-libs/physics#readme",
  "bugs": {
    "url": "https://github.com/starweb-libs/physics/issues"
  },
  "keywords": ["physics", "collision", "sat", "2d", "typescript", "browser", "starweb"],
  "type": "module",
  "devDependencies": {
    "typescript": "~6.0.2",
    "tsdown": "^0.22.0"
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "npm run build"
  },
  "files": ["dist"],
  "exports": {
    "./body.js": {
      "types": "./dist/body.d.mts",
      "@starweb-libs/source": "./src/body.ts",
      "import": "./dist/body.mjs"
    },
    "./collision.js": {
      "types": "./dist/collision.d.mts",
      "@starweb-libs/source": "./src/collision.ts",
      "import": "./dist/collision.mjs"
    },
    "./geometry.js": {
      "types": "./dist/geometry.d.mts",
      "@starweb-libs/source": "./src/geometry.ts",
      "import": "./dist/geometry.mjs"
    },
    "./overlap.js": {
      "types": "./dist/overlap.d.mts",
      "@starweb-libs/source": "./src/overlap.ts",
      "import": "./dist/overlap.mjs"
    },
    "./types.js": {
      "types": "./dist/types.d.mts",
      "@starweb-libs/source": "./src/types.ts",
      "import": "./dist/types.mjs"
    }
  }
}
